{
  "name": "tedit",
  "version": "0.0.1",
  "description": "Local visual template editor: design in browser, render PNG headlessly via CLI",
  "private": true,
  "type": "module",
  "bin": {
    "tedit": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/build-web.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "ui": "npm run build && node scripts/ui.mjs",
    "ui:demo": "npm run build && node scripts/ui.mjs examples/demo/card",
    "kill": "pkill -f dist/web/server.js || true",
    "tedit": "npm run build && node dist/cli/index.js",
    "render:demo": "npm run build && bash examples/demo/render-all.sh",
    "test": "npm run build && npm run test:unit && npm run test:parity && npm run test:cli && npm run test:editor && npm run test:e2e && npm run test:compositor",
    "test:unit": "node test/run-unit.mjs",
    "test:parity": "node e2e/run-parity.mjs",
    "test:cli": "node e2eCli/run-cli.mjs",
    "test:editor": "node e2e/run-editor.mjs",
    "test:e2e": "node e2e/run-e2e.mjs",
    "test:compositor": "node e2e/run-compositor-parity.mjs",
    "spike": "node spike/run-spike.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.3",
    "@types/pngjs": "^6.0.5",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "wawoff2": "^2.0.1"
  },
  "dependencies": {
    "fabric": "^7.4.0",
    "js-yaml": "^4.2.0",
    "konva": "^10.3.0",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.60.0",
    "pngjs": "^7.0.0"
  }
}
