{
  "teditVersion": "0.1",
  "canvas": { "width": 1000, "height": 600, "background": "#ffffff" },
  "elements": [
    {
      "id": "heading",
      "type": "text",
      "x": 60,
      "y": 40,
      "width": 880,
      "rotation": 0,
      "content": "設計時標題",
      "fontFamily": "Noto Sans TC",
      "fontSize": 48,
      "color": "#1a1a1a",
      "align": "left",
      "lineHeight": 1.3
    },
    {
      "id": "watermark",
      "type": "text",
      "x": 60,
      "y": 520,
      "width": 880,
      "rotation": 0,
      "content": "設計時標題",
      "fontFamily": "Noto Sans TC",
      "fontSize": 20,
      "color": "#999999",
      "align": "right",
      "lineHeight": 1.2
    },
    {
      "id": "hero",
      "type": "image",
      "x": 60,
      "y": 120,
      "width": 880,
      "height": 360,
      "rotation": 0,
      "src": "assets/images/test-photo.png",
      "fit": "cover"
    }
  ],
  "bindings": [
    { "var": "title", "element": "heading", "prop": "content", "type": "text" },
    { "var": "title", "element": "watermark", "prop": "content", "type": "text" },
    { "var": "photo", "element": "hero", "prop": "src", "type": "image" }
  ]
}
